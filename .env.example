# Copy to .env and fill in. The pipeline loads this automatically.
# .env is gitignored. Never commit real keys.

# --- REQUIRED for the default (build-only) pipeline ---

# Anthropic API key. The curate step runs headless Claude Code to pick the day's
# stories from the harvested pool. Get one at https://console.anthropic.com.
ANTHROPIC_API_KEY=

# --- OPTIONAL: extra sources ---

# Apify token. Only needed if you enable an apify_x or reddit_apify source in
# sources.json (scrapes X/Twitter handles + some subreddits). Sources that need
# it are skipped silently if it is unset. https://apify.com
APIFY_TOKEN=

# --- OPTIONAL: failure alerts ---

# Slack Incoming Webhook URL. If set, the pipeline pings you when a run fails or
# NotebookLM auth expires. Unset = silent (no-op). https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK=

# --- OPTIONAL: delivery (only if config.json delivery = "resend") ---

# Supabase Personal Access Token. Used to fetch the storage service key at
# runtime (never persisted) to host the audio + serve unsubscribe links.
SUPABASE_ACCESS_TOKEN=

# Resend API key for sending the episode email. https://resend.com
RESEND_API_KEY=

# Supabase project ref (the subdomain of your project URL). Or put it in
# supabase.json. Only used when delivery = "resend".
SUPABASE_PROJECT_REF=
